{
  "name": "multi-tenant-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Primitives for serving multiple tenants from a single MCP server",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/multi-tenant-mcp.git"
  },
  "homepage": "https://github.com/reaatech/multi-tenant-mcp#readme",
  "bugs": {
    "url": "https://github.com/reaatech/multi-tenant-mcp/issues"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@vitest/coverage-v8": "4.1.6",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "multi-tenant",
    "middleware",
    "tenant-isolation",
    "rate-limiting",
    "cost-accounting"
  ],
  "packageManager": "pnpm@10.22.0",
  "pnpm": {
    "overrides": {
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fast-xml-builder@<=1.1.6": ">=1.1.7",
      "fast-xml-builder@=1.1.5": ">=1.1.6",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<=10.1.0": ">=10.1.1"
    }
  }
}
