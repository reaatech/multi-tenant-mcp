{
  "name": "multi-tenant-mcp",
  "version": "1.0.0",
  "description": "Primitives for serving multiple tenants from a single MCP server",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "pnpm build:clean && pnpm build:esm && pnpm build:cjs && pnpm build:types",
    "build:clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/rename-cjs.js",
    "build:types": "tsc -p tsconfig.types.json && cp dist/types/index.d.ts dist/types/index.d.mts && cp dist/types/index.d.ts dist/types/index.d.cts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" --no-error-on-unmatched-pattern",
    "validate:package": "pnpm build && publint",
    "benchmark": "vitest run tests/performance",
    "docs:generate": "typedoc --out docs/api src/index.ts",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "multi-tenant",
    "middleware",
    "tenant-isolation",
    "rate-limiting",
    "cost-accounting"
  ],
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/multi-tenant-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/multi-tenant-mcp/issues"
  },
  "homepage": "https://github.com/reaatech/multi-tenant-mcp#readme",
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "redis": "^4.7.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^10.2.1",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.16.0",
    "prettier": "^3.4.0",
    "@types/express": "^4.17.0",
    "express": "^4.18.0",
    "publint": "^0.2.0",
    "typedoc": "^0.27.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
