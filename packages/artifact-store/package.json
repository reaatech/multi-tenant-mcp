{
  "name": "@reaatech/multi-tenant-mcp-artifact-store",
  "version": "0.1.0",
  "description": "Tenant-isolated artifact and file storage for multi-tenant MCP",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/multi-tenant-mcp.git",
    "directory": "packages/artifact-store"
  },
  "homepage": "https://github.com/reaatech/multi-tenant-mcp/tree/main/packages/artifact-store#readme",
  "bugs": {
    "url": "https://github.com/reaatech/multi-tenant-mcp/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/multi-tenant-mcp-types": "workspace:*",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1048.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  }
}
